// This is your Prisma schema file,
generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth models
model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  name               String?
  did                String?
  location           String?
  state              String?
  district           String?
  village            String?
  language           String?        @default("hi")
  onboarded          Boolean?       @default(false)
  role               String?        @default("user")
  balance            Float?         @default(5000)
  savingsLockedUntil DateTime?
  averageTransactionAmount Float?    @default(0)
  lastLoginState     String?
  riskScore          Float?         @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime?      @updatedAt
  identities         UserIdentity[]
  credentials        Credential[]
  documents          Document[]
  transactionsSent   Transaction[]  @relation("SentTransactions")
  transactionsReceived Transaction[] @relation("ReceivedTransactions")
  welfarePayments    WelfarePayment[]
  isDeleted          Boolean        @default(false)

  @@index([email])
  @@index([did])
}

model UserIdentity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String // 'Google', 'GitHub', 'EmailPassword', 'PhoneOTP', etc.
  providerId String // Provider's unique user ID (or email for email/password)
  metadata   Json? // Provider-specific data (passwordHash, tokens, profile data, etc.)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  @@unique([provider, providerId])
  @@index([userId])
}

model WelfareScheme {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String
  benefits    String[]
  eligibility String[]
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)
}

model Credential {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  type             String[]
  issuer           String
  issuanceDate     DateTime
  credentialSubject Json
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)

  @@index([userId])
}

model Transaction {
  id          String   @id @default(uuid())
  senderId    String?
  sender      User?    @relation("SentTransactions", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?    @relation("ReceivedTransactions", fields: [receiverId], references: [id])
  amount      Float
  status      String   @default("completed") // 'completed', 'pending', 'offline'
  type        String   @default("p2p")       // 'p2p', 'welfare'
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([senderId])
  @@index([receiverId])
}

model WelfarePayment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  schemeName String
  amount     Float
  status     String   @default("paid")
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  @@index([userId])
}

model Document {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  schemeId       String?
  docType        String
  url            String?
  storageKey     String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  balance   Float    @default(5000)
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  @@index([userId])
}

model Otp {
  id         String   @id @default(uuid())
  identifier String   // Phone number or email address
  type       String   // 'phone' or 'email'
  otp        String   // Hashed OTP
  expiresAt  DateTime
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  purpose    String?  // 'login', 'registration', 'password_reset', '2fa', etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  @@index([identifier, type])
  @@index([expiresAt])
  @@index([identifier, type, verified])
}