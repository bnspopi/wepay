# Server
PORT=9000
NODE_ENV=development

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Database (for production with Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/wepay

# Frontend domain (for OAuth redirects)
FRONTEND_DOMAIN=http://localhost:5000

# LLM (optional)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
